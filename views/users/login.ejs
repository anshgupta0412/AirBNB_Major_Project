<% layout("/layouts/boilerplate")%>

<div class="row mt-5">
  <h1 class="col-6 offset-3 text-center mb-4">Login on WanderLust</h1>

  <div class="col-6 offset-3">
    <form action="/login" method="POST" class="needs-validation" novalidate>

      <!-- Username -->
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input 
          type="text" 
          name="username" 
          id="username" 
          class="form-control" 
          placeholder="Enter username"
          required
        />
        <div class="invalid-feedback">Please enter a username</div>
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input 
          type="password" 
          name="password" 
          id="password" 
          class="form-control" 
          placeholder="Enter password"
          required
        />
      </div>

      <!-- Button -->
      <button class="btn btn-success w-100">Login Up</button>

    </form>
  </div>
</div>
